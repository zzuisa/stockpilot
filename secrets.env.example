# StockPilot 密钥模板(说明书 §15 .env)
# 复制为 secrets.env 填入真实值,deploy.sh 会据此创建 k8s Secret:
#   cp secrets.env.example secrets.env && vim secrets.env && ./deploy.sh secrets
# 留空/保持 changeme 的集成会被应用自动跳过(只告警不崩溃)

DB_PASSWORD=changeme
GRAFANA_PASSWORD=changeme

# Trading212(demo 跑通后再切 live)
T212_API_KEY=
T212_API_SECRET=
T212_ENV=demo

# 行情与新闻
FINNHUB_TOKEN=

# SiliconFlow LLM (OpenAI-compatible, DeepSeek-V3.2)
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=Pro/deepseek-ai/DeepSeek-V3.2
# 工具代理(function-calling)用 Qwen；自主调用富途 skills 后交 DeepSeek 分析
SILICONFLOW_TOOL_MODEL=Qwen/Qwen2.5-72B-Instruct

# ★ 富途 OpenAPI(非美股优质信息源)——需在可达处运行 OpenD 并登录富途账号
# 集群 pod 需能 TCP 连到 FUTU_OPEND_HOST:FUTU_OPEND_PORT；连不上则自动跳过、回落原有源。
# 启用后还需在该运行环境安装 futu-api（pip install "futu-api"）——未加入镜像默认依赖以免影响构建。
FUTU_ENABLED=false
FUTU_OPEND_HOST=127.0.0.1
FUTU_OPEND_PORT=11111
FUTU_LOGIN_ACCOUNT=              # 多数情况在 OpenD 端已登录则留空
FUTU_LOGIN_PWD=

# 短线建议缓存(秒)/每标的保留条数
ADVICE_CACHE_TTL=1800
ADVICE_KEEP=5

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ADMIN_USER_ID=          # 只有这个 user_id 能点确认下单按钮(§17)
TELEGRAM_MODE=polling            # polling | webhook
TELEGRAM_WEBHOOK_SECRET=

# ★ SMTP 邮件 (端口 465=隐式TLS, 587=STARTTLS)
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# 风控参数(§19)
RISK_MAX_ORDER_EUR=200
RISK_MAX_POSITION_PCT=15
RISK_DAILY_LOSS_LIMIT_EUR=100
